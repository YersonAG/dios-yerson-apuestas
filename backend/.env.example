# Variables de entorno para El Dios Yerson Backend

# Base de datos PostgreSQL (Railway)
DATABASE_URL="postgresql://user:password@host:port/database"
DIRECT_DATABASE_URL="postgresql://user:password@host:port/database"

# JWT Secret para autenticación
JWT_SECRET="tu-jwt-secret-super-seguro"

# URL del frontend (CORS)
FRONTEND_URL="https://tu-frontend.vercel.app"

# Ambiente
NODE_ENV="production"

# ===========================================
# CONFIGURACIÓN DE IA (Opcional)
# ===========================================
# El sistema tiene respuestas inteligentes locales que funcionan sin configuración.
# Si quieres IA avanzada, configura UNA de las siguientes opciones:

# 🌟 Opción 1: Groq (RECOMENDADO - GRATIS y rápido)
# Crea tu cuenta en: https://console.groq.com/
# Obtén tu API key en: https://console.groq.com/keys
GROQ_API_KEY="gsk_tu-api-key-de-groq"
GROQ_BASE_URL="https://api.groq.com/openai/v1"  # opcional, ya está por defecto
GROQ_MODEL="llama-3.3-70b-versatile"  # modelos disponibles: llama-3.3-70b-versatile, llama-3.1-8b-instant, mixtral-8x7b-32768

# Opción 2: Z-AI SDK (servicio personalizado)
# ZAI_BASE_URL="https://tu-servicio-ai.com/v1"
# ZAI_API_KEY="tu-api-key"

# Opción 3: OpenAI API
# OPENAI_API_KEY="sk-tu-openai-api-key"
# OPENAI_BASE_URL="https://api.openai.com/v1"  # opcional, para proxies
# OPENAI_MODEL="gpt-4o-mini"

# Opción 4: Zhipu AI API (GLM-4)
# ZHIPU_API_KEY="tu-zhipu-api-key"

# ===========================================
# NOTA: Si no configuras ninguna opción de IA,
# el sistema usará respuestas locales inteligentes
# que funcionan perfectamente para:
# - Análisis de equipos
# - Información de ligas
# - Conceptos de apuestas
# - Generación de combinadas
# ===========================================
